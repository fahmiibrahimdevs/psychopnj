# MQTT Broker Configuration
MQTT_BROKER_HOST=xxx.xx.xxx.xxx
MQTT_BROKER_PORT=xxxx
MQTT_USERNAME=xxxx
MQTT_PASSWORD=xxxx

# Laravel API Configuration
API_BASE_URL=http://psychorobotic.test
API_DOOR_LOCK_ENDPOINT=/api/door-lock
API_ABSENSI_ENDPOINT=/api/absensi

# MQTT Topics
TOPIC_ACCESS_CHECK=psychorobotic/doorlock/access/check
TOPIC_ACCESS_RESPONSE=psychorobotic/doorlock/access/response
TOPIC_REGISTER_REQUEST=psychorobotic/rfid/register/request
TOPIC_REGISTER_RESPONSE=psychorobotic/rfid/register/response

# Debug Mode
DEBUG=true
